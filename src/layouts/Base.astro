---
interface Props {
  title: string;
  description?: string;
}
const {
  title,
  description = 'Small-batch coffee roastery on Maple Street, Springfield. Roasted Tuesdays.',
} = Astro.props;
const path = Astro.url.pathname;
const isCurrent = (p: string) => path === p || (p !== '/' && path.startsWith(p));
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Inter:wght@400;500;600&display=swap" />
  <style is:global>
    :root {
      --bean: #3a2418;
      --bean-deep: #2a1711;
      --crema: #f6efe6;
      --crema-warm: #efe4d4;
      --copper: #b46a3b;
      --copper-deep: #8f5129;
      --ink: #1f1612;
      --rule: rgba(58, 36, 24, 0.14);
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      color: var(--ink);
      background: var(--crema);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }
    h1, h2, h3 {
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 700;
      line-height: 1.12;
      margin: 0 0 .5em;
      color: var(--bean-deep);
      letter-spacing: -0.01em;
    }
    h1 { font-size: clamp(2.25rem, 5.5vw, 3.75rem); }
    h2 { font-size: 1.875rem; margin-top: 2em; }
    h3 { font-size: 1.25rem; margin-top: 1.6em; }
    p { margin: 1em 0; }
    a { color: var(--copper-deep); text-underline-offset: 3px; }
    a:hover { color: var(--bean); }
    ul { padding-left: 1.25em; }
    li { margin: .25em 0; }
    hr { border: 0; border-top: 1px solid var(--rule); margin: 3em 0; }
    .mast {
      border-bottom: 1px solid var(--rule);
      background: var(--crema-warm);
    }
    .mast-inner {
      max-width: 880px;
      margin: 0 auto;
      padding: 28px 24px 20px;
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 16px;
    }
    .brand {
      font-family: 'Fraunces', Georgia, serif;
      font-weight: 700;
      font-size: 1.4rem;
      color: var(--bean-deep);
      text-decoration: none;
      letter-spacing: -0.01em;
    }
    .brand .amp { color: var(--copper); font-weight: 400; font-style: italic; }
    .brand small {
      display: block;
      font-family: 'Inter', sans-serif;
      font-weight: 400;
      font-size: 0.7rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--bean);
      opacity: 0.75;
      margin-top: 2px;
    }
    nav { display: flex; gap: 28px; }
    nav a {
      color: var(--bean);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.95rem;
      padding-bottom: 3px;
      border-bottom: 2px solid transparent;
    }
    nav a:hover { color: var(--copper-deep); }
    nav a.current { border-bottom-color: var(--copper); color: var(--bean-deep); }
    .wrap { max-width: 720px; margin: 0 auto; padding: 56px 24px 32px; }
    .lede { font-size: 1.15rem; color: var(--bean); max-width: 56ch; }
    .eyebrow {
      font-size: 0.75rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--copper-deep);
      font-weight: 600;
      margin: 0 0 .5rem;
    }
    .card-list {
      list-style: none;
      padding: 0;
      margin: 1.5em 0;
      display: grid;
      gap: 1rem;
    }
    .card-list li {
      padding: 1rem 1.25rem;
      background: var(--crema-warm);
      border-left: 3px solid var(--copper);
      border-radius: 2px;
    }
    .card-list strong { display: block; font-family: 'Fraunces', serif; font-size: 1.05rem; color: var(--bean-deep); margin-bottom: 2px; }
    .card-list .notes { font-size: 0.92rem; color: var(--bean); }
    .facts {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 6px 24px;
      margin: 1.5em 0;
      font-size: 0.97rem;
    }
    .facts dt {
      font-weight: 600;
      color: var(--bean-deep);
    }
    .facts dd {
      margin: 0;
      color: var(--bean);
    }
    footer {
      border-top: 1px solid var(--rule);
      padding: 28px 24px 40px;
      text-align: center;
      color: var(--bean);
      font-size: 0.875rem;
      background: var(--crema-warm);
    }
    footer .small { font-size: 0.75rem; opacity: 0.7; margin-top: 6px; letter-spacing: 0.04em; }
    @media (max-width: 540px) {
      .mast-inner { padding-bottom: 8px; }
      nav { width: 100%; padding-top: 4px; overflow-x: auto; }
    }
  </style>
</head>
<body>
  <header class="mast">
    <div class="mast-inner">
      <a href="/" class="brand">
        Acme Coffee <span class="amp">&amp;</span> Roasters
        <small>est. 2018 · Springfield</small>
      </a>
      <nav>
        <a href="/" class={isCurrent('/') ? 'current' : ''}>Home</a>
        <a href="/about/" class={isCurrent('/about') ? 'current' : ''}>About</a>
        <a href="/wholesale/" class={isCurrent('/wholesale') ? 'current' : ''}>Wholesale</a>
        <a href="/contact/" class={isCurrent('/contact') ? 'current' : ''}>Visit</a>
      </nav>
    </div>
  </header>
  <main class="wrap">
    <slot />
  </main>
  <footer>
    412 Maple St · Springfield · <a href="mailto:hello@acmecoffee.example">hello@acmecoffee.example</a>
    <div class="small">© Acme Coffee Roasters</div>
  </footer>
</body>
</html>
