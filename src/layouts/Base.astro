---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Small-batch coffee roastery in Springfield.' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;700&family=Inter:wght@400;500;600&display=swap" />
  <style is:global>
    :root {
      --bean: #3a2418;
      --crema: #f6efe6;
      --copper: #b46a3b;
      --ink: #1f1612;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      font-family: 'Inter', system-ui, sans-serif;
      color: var(--ink);
      background: var(--crema);
      line-height: 1.6;
    }
    h1, h2 { font-family: 'Fraunces', Georgia, serif; font-weight: 700; line-height: 1.15; margin: 0 0 .5em; }
    h1 { font-size: clamp(2rem, 5vw, 3.5rem); }
    h2 { font-size: 1.75rem; color: var(--bean); }
    a { color: var(--copper); }
    .wrap { max-width: 720px; margin: 0 auto; padding: 48px 24px; }
    nav { display: flex; gap: 24px; padding: 24px; border-bottom: 1px solid rgba(0,0,0,.08); }
    nav a { color: var(--bean); text-decoration: none; font-weight: 600; }
    nav a:hover { color: var(--copper); }
    footer { border-top: 1px solid rgba(0,0,0,.08); padding: 24px; text-align: center; color: var(--bean); font-size: .875rem; }
  </style>
</head>
<body>
  <nav>
    <a href="/">Acme Coffee</a>
    <a href="/about/">About</a>
    <a href="/contact/">Contact</a>
  </nav>
  <main class="wrap">
    <slot />
  </main>
  <footer>© Acme Coffee Roasters · Springfield</footer>
</body>
</html>
