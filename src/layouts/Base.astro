---
import Masthead from '../components/Masthead.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site';

interface Props {
  title: string;
  description?: string;
}
const { title, description = SITE.description } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,100..900,50..100,0..1;1,9..144,100..900,50..100,0..1&family=Inter:wght@400;500;600&display=swap"
  />
  <style is:global>
    :root {
      --bean: #2a1a12;
      --ink: #1a120e;
      --crema: #f4ece0;
      --paper: #faf6ef;
      --copper: #a85a2b;
      --copper-hover: #8f4a20;
      --pine: #2f4a3a;
      --rule: rgba(42, 26, 18, 0.12);
      --rule-strong: rgba(42, 26, 18, 0.24);
      --muted: #6b5a4e;
      --focus: #a85a2b;

      --serif: "Fraunces", "Times New Roman", Georgia, serif;
      --sans: "Inter", -apple-system, "Helvetica Neue", Arial, sans-serif;

      --fs-eyebrow: 0.75rem;
      --fs-small:  0.8125rem;
      --fs-ui:     0.875rem;
      --fs-body:   1.0625rem;
      --fs-lede:   clamp(1.125rem, 1rem + 0.4vw, 1.375rem);
      --fs-h3:     clamp(1.25rem, 1.1rem + 0.6vw, 1.5rem);
      --fs-h2:     clamp(1.75rem, 1.4rem + 1.6vw, 2.5rem);
      --fs-h1:     clamp(2.25rem, 1.6rem + 3.2vw, 4rem);
      --fs-display:clamp(3rem, 1.8rem + 6vw, 6.5rem);

      --lh-tight: 1.02;
      --lh-snug:  1.18;
      --lh-body:  1.55;
      --lh-prose: 1.65;

      --tr-eyebrow: 0.14em;
      --tr-tight:   -0.02em;
      --tr-display: -0.03em;

      --s-1: 0.25rem;
      --s-2: 0.5rem;
      --s-3: 0.75rem;
      --s-4: 1rem;
      --s-5: 1.5rem;
      --s-6: 2rem;
      --s-7: 3rem;
      --s-8: 4rem;
      --s-9: 6rem;
      --s-10: 8rem;

      --r-sm: 2px;
      --r-md: 4px;
      --r-lg: 8px;

      --dur-fast: 120ms;
      --dur-med: 220ms;
      --dur-slow: 380ms;
      --ease-out: cubic-bezier(.2,.7,.2,1);
      --ease-in-out: cubic-bezier(.5,.05,.5,.95);

      --container: 1180px;
      --prose: 68ch;
      --masthead: 64px;
    }

    * { box-sizing: border-box; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--crema);
      color: var(--ink);
      font-family: var(--sans);
      font-size: var(--fs-body);
      line-height: var(--lh-body);
      font-feature-settings: "ss01", "cv11";
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
    }

    .serif {
      font-family: var(--serif);
      font-variation-settings: "opsz" 144, "SOFT" 50, "WONK" 0;
    }
    .serif--text {
      font-family: var(--serif);
      font-variation-settings: "opsz" 14, "SOFT" 50, "WONK" 0;
    }
    .serif--italic {
      font-family: var(--serif);
      font-style: italic;
      font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
    }

    h1, h2, h3, h4 {
      margin: 0;
      font-family: var(--serif);
      color: var(--ink);
      letter-spacing: var(--tr-tight);
      line-height: var(--lh-snug);
      font-variation-settings: "opsz" 96, "SOFT" 50, "WONK" 0;
      font-weight: 420;
    }
    h1 { font-size: var(--fs-h1); line-height: var(--lh-tight); letter-spacing: var(--tr-display); font-variation-settings: "opsz" 144, "SOFT" 60, "WONK" 0; }
    h2 { font-size: var(--fs-h2); }
    h3 { font-size: var(--fs-h3); font-variation-settings: "opsz" 48, "SOFT" 50, "WONK" 0; }

    p { margin: 0 0 1em; }

    .eyebrow {
      font-family: var(--sans);
      font-size: var(--fs-eyebrow);
      text-transform: uppercase;
      letter-spacing: var(--tr-eyebrow);
      font-weight: 500;
      color: var(--muted);
      display: inline-flex;
      align-items: center;
      gap: var(--s-2);
    }

    .lede {
      font-family: var(--serif);
      font-variation-settings: "opsz" 24, "SOFT" 80;
      font-size: var(--fs-lede);
      line-height: 1.4;
      color: var(--bean);
      font-weight: 380;
      letter-spacing: -0.01em;
    }

    .label {
      font-family: var(--sans);
      font-size: var(--fs-ui);
      font-weight: 500;
      color: var(--bean);
    }

    .small {
      font-size: var(--fs-small);
      color: var(--muted);
    }

    .tnum { font-variant-numeric: tabular-nums; font-feature-settings: "tnum"; }

    .origin {
      font-family: var(--sans);
      font-size: var(--fs-ui);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 600;
      color: var(--bean);
    }

    .motif {
      display: inline-flex;
      align-items: center;
      gap: 0.3em;
      color: var(--copper);
      font-family: var(--serif);
      font-variation-settings: "opsz" 14;
    }
    .motif::before { content: "·"; font-size: 1.4em; line-height: 0; position: relative; top: -0.08em; }
    .motif::after  { content: "›"; font-weight: 500; }

    a {
      color: var(--bean);
      text-decoration: none;
      background-image: linear-gradient(var(--copper), var(--copper));
      background-size: 100% 1px;
      background-position: 0 100%;
      background-repeat: no-repeat;
      transition: background-size var(--dur-med) var(--ease-out);
    }
    a:hover { background-size: 100% 2px; }
    a:focus-visible {
      outline: 2px solid var(--focus);
      outline-offset: 3px;
      border-radius: 2px;
    }

    a[data-external]::after {
      content: "↗";
      margin-left: 0.25em;
      color: var(--muted);
      font-size: 0.85em;
    }

    hr.rule {
      border: 0;
      border-top: 1px solid var(--rule);
      margin: var(--s-7) 0;
    }
    .rule-motif {
      display: flex;
      align-items: center;
      gap: var(--s-3);
      color: var(--copper);
      margin: var(--s-7) 0;
    }
    .rule-motif::before, .rule-motif::after {
      content: "";
      flex: 1;
      height: 1px;
      background: var(--rule);
    }
    .rule-motif span {
      font-family: var(--serif);
      font-style: italic;
      font-variation-settings: "opsz" 14, "SOFT" 100, "WONK" 1;
      font-size: 1.3em;
      line-height: 1;
    }

    ::selection { background: var(--copper); color: var(--crema); }

    :focus-visible {
      outline: 2px solid var(--focus);
      outline-offset: 2px;
      border-radius: 2px;
    }

    .container {
      max-width: var(--container);
      margin: 0 auto;
      padding: 0 var(--s-5);
    }
    .prose { max-width: var(--prose); }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        transition-duration: 0.01ms !important;
      }
    }

    /* ───────── Masthead ───────── */
    .masthead {
      border-bottom: 1px solid var(--rule);
      background: var(--crema);
      position: sticky;
      top: 0;
      z-index: 50;
    }
    .masthead__inner {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: var(--s-5);
      padding: var(--s-4) var(--s-5);
      max-width: var(--container);
      margin: 0 auto;
      min-height: var(--masthead);
    }

    .wordmark {
      display: inline-flex;
      align-items: baseline;
      gap: 0.55rem;
      color: var(--ink);
      background: none;
      line-height: 1;
    }
    .wordmark__name {
      font-family: var(--serif);
      font-size: 1.375rem;
      letter-spacing: -0.025em;
      font-variation-settings: "opsz" 48, "SOFT" 40, "WONK" 0;
      font-weight: 440;
    }
    .wordmark__amp {
      font-family: var(--serif);
      font-style: italic;
      font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
      font-weight: 400;
      color: var(--copper);
      font-size: 1.45rem;
      margin: 0 -0.05em;
    }
    .wordmark__tag {
      font-family: var(--sans);
      font-size: 0.6875rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      font-weight: 500;
      color: var(--muted);
      padding-left: 0.7rem;
      border-left: 1px solid var(--rule-strong);
      margin-left: 0.3rem;
      align-self: center;
      padding-top: 0.1em;
      padding-bottom: 0.1em;
    }

    .nav {
      display: flex;
      gap: var(--s-6);
      justify-content: center;
    }
    .nav a {
      font-family: var(--sans);
      font-size: var(--fs-ui);
      font-weight: 500;
      color: var(--bean);
      background: none;
      position: relative;
      padding: var(--s-2) 0;
    }
    .nav a::after {
      content: "";
      position: absolute;
      left: 0; right: 0; bottom: -2px;
      height: 1px;
      background: var(--copper);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform var(--dur-med) var(--ease-out);
    }
    .nav a:hover::after { transform: scaleX(1); }
    .nav a.is-active { color: var(--ink); }
    .nav a.is-active::after {
      transform: scaleX(1);
      background: var(--ink);
    }

    .masthead__cta {
      font-family: var(--sans);
      font-size: var(--fs-ui);
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: var(--s-2);
    }
    .masthead__cta .dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--pine);
      display: inline-block;
    }

    /* ───────── Buttons ───────── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: var(--s-2);
      font-family: var(--sans);
      font-size: var(--fs-ui);
      font-weight: 500;
      padding: 0.7rem 1.1rem;
      border: 1px solid transparent;
      border-radius: var(--r-md);
      cursor: pointer;
      transition: transform var(--dur-fast) var(--ease-out),
                  background var(--dur-med) var(--ease-out),
                  color var(--dur-med) var(--ease-out),
                  border-color var(--dur-med) var(--ease-out);
      background: none;
      min-height: 44px;
      text-align: left;
      letter-spacing: 0.005em;
      text-decoration: none;
      background-image: none;
    }
    .btn--primary {
      background: var(--bean);
      color: var(--crema);
      border-color: var(--bean);
    }
    .btn--primary:hover { background: var(--ink); border-color: var(--ink); }
    .btn--primary:active { transform: translateY(1px); }

    .btn--accent {
      background: var(--copper);
      color: var(--paper);
      border-color: var(--copper);
    }
    .btn--accent:hover { background: var(--copper-hover); border-color: var(--copper-hover); }

    .btn--secondary {
      background: transparent;
      color: var(--bean);
      border-color: var(--rule-strong);
    }
    .btn--secondary:hover { border-color: var(--bean); }

    .btn--ghost {
      background: transparent;
      color: var(--bean);
      border-color: transparent;
      padding-left: 0;
      padding-right: 0;
    }
    .btn--ghost::after {
      content: "→";
      transition: transform var(--dur-med) var(--ease-out);
    }
    .btn--ghost:hover::after { transform: translateX(3px); }

    .btn[disabled], .btn[aria-disabled="true"] {
      opacity: 0.5;
      cursor: not-allowed;
      pointer-events: none;
    }

    /* ───────── Offering Card ───────── */
    .offering {
      display: grid;
      grid-template-columns: 4px 1fr;
      gap: var(--s-5);
      padding: var(--s-5) 0 var(--s-5) var(--s-5);
      border-bottom: 1px solid var(--rule);
      transition: background var(--dur-med) var(--ease-out);
      position: relative;
    }
    .offering::before {
      content: "";
      position: absolute;
      left: 0; top: var(--s-5); bottom: var(--s-5);
      width: 2px;
      background: var(--copper);
      transition: width var(--dur-med) var(--ease-out), background var(--dur-med) var(--ease-out);
    }
    .offering:hover::before { width: 4px; }
    .offering:hover { background: var(--paper); }

    .offering__body {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: var(--s-3) var(--s-6);
      align-items: start;
    }
    .offering__head {
      display: flex;
      flex-direction: column;
      gap: var(--s-1);
    }
    .offering__origin {
      display: flex;
      align-items: baseline;
      gap: var(--s-3);
      flex-wrap: wrap;
    }
    .offering__country {
      font-family: var(--sans);
      font-size: 0.8125rem;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-weight: 600;
      color: var(--copper);
    }
    .offering__title {
      font-family: var(--serif);
      font-size: clamp(1.375rem, 1.1rem + 0.9vw, 1.75rem);
      line-height: 1.15;
      letter-spacing: -0.015em;
      font-variation-settings: "opsz" 48, "SOFT" 50;
      color: var(--ink);
      font-weight: 420;
    }
    .offering__meta {
      display: flex;
      flex-wrap: wrap;
      gap: var(--s-2) var(--s-4);
      margin-top: var(--s-3);
      font-family: var(--sans);
      font-size: 0.8125rem;
      color: var(--muted);
      line-height: 1.4;
    }
    .offering__meta dt {
      font-weight: 500;
      color: var(--bean);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-size: 0.6875rem;
      margin-right: 0.4em;
    }
    .offering__meta dd { margin: 0; display: inline; }
    .offering__meta .pair { display: inline-flex; align-items: baseline; gap: 0.2em; }

    .offering__notes {
      font-family: var(--serif);
      font-variation-settings: "opsz" 14, "SOFT" 80;
      font-style: italic;
      font-size: 1.0625rem;
      line-height: 1.45;
      color: var(--bean);
      margin-top: var(--s-4);
      max-width: 48ch;
      font-weight: 380;
    }

    .offering__price {
      text-align: right;
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: var(--s-1);
    }
    .offering__price .amount {
      font-family: var(--serif);
      font-size: 1.625rem;
      font-variation-settings: "opsz" 48, "SOFT" 40;
      font-weight: 420;
      letter-spacing: -0.01em;
      color: var(--ink);
      line-height: 1;
    }
    .offering__price .weight {
      font-family: var(--sans);
      font-size: 0.75rem;
      color: var(--muted);
      letter-spacing: 0.04em;
    }
    .offering__price-note { margin-top: 0.5rem; }

    .offering__actions {
      display: flex;
      gap: var(--s-3);
      margin-top: var(--s-5);
      align-items: center;
      flex-wrap: wrap;
    }

    .offering.is-sold-out { opacity: 0.62; }
    .offering.is-sold-out::before { background: var(--muted); }
    .offering.is-sold-out:hover { background: transparent; }
    .offering.is-sold-out:hover::before { width: 2px; }
    .offering__status {
      display: inline-flex;
      align-items: center;
      gap: var(--s-2);
      font-family: var(--sans);
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 500;
    }
    .offering__status::before {
      content: "";
      width: 8px; height: 8px;
      border: 1px solid var(--muted);
      border-radius: 50%;
    }
    .offering__status--live::before {
      background: var(--pine);
      border-color: var(--pine);
    }
    .offering__status--soon::before {
      border-style: dashed;
    }

    /* ───────── Facts list ───────── */
    .facts {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 0;
      border-top: 1px solid var(--rule);
    }
    .facts > * {
      padding: var(--s-4) 0;
      border-bottom: 1px solid var(--rule);
      margin: 0;
    }
    .facts dt {
      font-family: var(--sans);
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--muted);
      padding-top: calc(var(--s-4) + 2px);
    }
    .facts dd {
      font-family: var(--serif);
      font-variation-settings: "opsz" 14, "SOFT" 60;
      font-size: 1.0625rem;
      color: var(--bean);
      line-height: 1.45;
    }

    /* ───────── Pull quote ───────── */
    .pullquote {
      font-family: var(--serif);
      font-variation-settings: "opsz" 72, "SOFT" 80, "WONK" 0;
      font-size: clamp(1.625rem, 1.2rem + 1.4vw, 2.25rem);
      line-height: 1.22;
      color: var(--ink);
      max-width: 22ch;
      letter-spacing: -0.015em;
      padding-left: var(--s-5);
      border-left: 1px solid var(--copper);
      margin: var(--s-7) 0;
      font-weight: 380;
    }

    /* ───────── Drop cap ───────── */
    .dropcap::first-letter {
      font-family: var(--serif);
      font-variation-settings: "opsz" 144, "SOFT" 80;
      font-size: 4.5em;
      float: left;
      line-height: 0.82;
      margin: 0.08em 0.08em 0 -0.05em;
      color: var(--copper);
      font-weight: 420;
    }

    /* ───────── Pricing table ───────── */
    .ptable {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--sans);
      font-size: 0.9375rem;
    }
    .ptable th, .ptable td {
      text-align: left;
      padding: var(--s-4) var(--s-3);
      border-bottom: 1px solid var(--rule);
    }
    .ptable th {
      font-size: 0.6875rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--muted);
    }
    .ptable td.num {
      font-variant-numeric: tabular-nums;
      font-family: var(--serif);
      font-variation-settings: "opsz" 14;
      font-size: 1.0625rem;
      color: var(--ink);
    }
    .ptable tr:last-child td { border-bottom: 0; }

    /* ───────── Form ───────── */
    .form {
      display: grid;
      gap: var(--s-5);
      max-width: 560px;
    }
    .field {
      display: grid;
      gap: var(--s-2);
    }
    .field label {
      font-family: var(--sans);
      font-size: 0.8125rem;
      font-weight: 500;
      color: var(--bean);
      letter-spacing: 0.02em;
    }
    .field .help {
      font-size: 0.75rem;
      color: var(--muted);
    }
    .field input,
    .field textarea,
    .field select {
      font-family: var(--sans);
      font-size: 0.9375rem;
      padding: 0.75rem 0.85rem;
      border: 1px solid var(--rule-strong);
      border-radius: var(--r-sm);
      background: var(--paper);
      color: var(--ink);
      transition: border-color var(--dur-fast) var(--ease-out), box-shadow var(--dur-fast) var(--ease-out);
      min-height: 44px;
    }
    .field input:focus,
    .field textarea:focus,
    .field select:focus {
      outline: none;
      border-color: var(--copper);
      box-shadow: 0 0 0 3px rgba(168, 90, 43, 0.18);
    }

    /* ───────── Footer ───────── */
    .footer {
      border-top: 1px solid var(--rule);
      margin-top: var(--s-10);
      padding: var(--s-7) 0 var(--s-6);
      background: var(--crema);
    }
    .footer__inner {
      display: grid;
      grid-template-columns: 1.3fr 1fr 1fr 1fr;
      gap: var(--s-6);
      max-width: var(--container);
      margin: 0 auto;
      padding: 0 var(--s-5);
    }
    .footer__col h4 {
      font-family: var(--sans);
      font-size: 0.6875rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      font-weight: 600;
      color: var(--muted);
      margin-bottom: var(--s-3);
      font-weight: 600;
    }
    .footer__col p, .footer__col a, .footer__col li {
      font-family: var(--sans);
      font-size: 0.9375rem;
      color: var(--bean);
      line-height: 1.55;
    }
    .footer__col ul { list-style: none; padding: 0; margin: 0; display: grid; gap: var(--s-2); }
    .footer__blurb { margin-top: 1rem; max-width: 32ch; color: var(--muted); }
    .footer__sub { font-size: 0.8125rem; color: var(--muted); margin-bottom: 0.75rem; }
    .footer__bottom {
      max-width: var(--container);
      margin: var(--s-7) auto 0;
      padding: var(--s-5) var(--s-5) 0;
      border-top: 1px solid var(--rule);
      display: flex;
      justify-content: space-between;
      font-size: 0.75rem;
      color: var(--muted);
      letter-spacing: 0.04em;
      flex-wrap: wrap;
      gap: var(--s-3);
    }

    /* ───────── Hero ───────── */
    .hero {
      padding: var(--s-9) 0 var(--s-7);
      max-width: var(--container);
      margin: 0 auto;
    }
    .hero--operational { padding-top: var(--s-8); }
    .hero__eyebrow-row {
      display: flex;
      align-items: center;
      gap: var(--s-3);
      margin-bottom: var(--s-5);
      padding: 0 var(--s-5);
    }
    .hero__title {
      font-family: var(--serif);
      font-size: var(--fs-display);
      font-variation-settings: "opsz" 144, "SOFT" 60, "WONK" 0;
      line-height: 0.98;
      letter-spacing: var(--tr-display);
      color: var(--ink);
      padding: 0 var(--s-5);
      max-width: 18ch;
      font-weight: 420;
      margin: 0;
    }
    .hero__title em {
      font-style: italic;
      font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
      color: var(--copper);
    }
    .hero__lede {
      font-family: var(--serif);
      font-variation-settings: "opsz" 24, "SOFT" 80;
      font-size: clamp(1.125rem, 0.95rem + 0.5vw, 1.375rem);
      color: var(--bean);
      max-width: 48ch;
      margin-top: var(--s-5);
      padding: 0 var(--s-5);
      line-height: 1.4;
      font-weight: 380;
    }

    /* ───────── Week strip ───────── */
    .week-strip {
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      margin: var(--s-7) 0 0;
      padding: var(--s-5) 0;
      background: var(--paper);
    }
    .week-strip__inner {
      max-width: var(--container);
      margin: 0 auto;
      padding: 0 var(--s-5);
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: var(--s-6);
      align-items: center;
    }
    .week-strip__label {
      font-family: var(--sans);
      font-size: 0.6875rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: var(--s-2);
      white-space: nowrap;
    }
    .week-strip__label .dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--pine);
      animation: pulse 2.4s var(--ease-in-out) infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }
    .week-strip__titles {
      font-family: var(--serif);
      font-variation-settings: "opsz" 18, "SOFT" 60;
      font-size: 0.9375rem;
      color: var(--bean);
    }
    .week-strip__titles strong { font-weight: 420; color: var(--ink); }
    .week-strip__country { color: var(--muted); }
    .week-strip__titles .sep {
      color: var(--copper);
      margin: 0 0.5em;
      font-style: italic;
      font-variation-settings: "opsz" 14, "SOFT" 100, "WONK" 1;
    }

    /* ───────── Section heads ───────── */
    .section-head {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: var(--s-6);
      align-items: baseline;
      padding: var(--s-8) var(--s-5) var(--s-5);
      max-width: var(--container);
      margin: 0 auto;
    }
    .section-head__kicker {
      font-family: var(--sans);
      font-size: 0.6875rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--muted);
      font-weight: 600;
      display: flex;
      align-items: center;
      gap: var(--s-3);
    }
    .section-head__kicker::before {
      content: "·";
      color: var(--copper);
      font-size: 1.6em;
      line-height: 0;
      position: relative;
      top: -0.1em;
    }
    .section-head__title {
      font-family: var(--serif);
      font-size: var(--fs-h2);
      font-variation-settings: "opsz" 72, "SOFT" 50;
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: var(--ink);
      font-weight: 420;
    }
    .section-head__body {
      margin-top: 0.75rem;
      color: var(--muted);
      font-family: var(--sans);
      font-size: 0.9375rem;
      max-width: 50ch;
    }

    /* Prose page wrapper */
    .page {
      max-width: var(--container);
      margin: 0 auto;
      padding: var(--s-8) var(--s-5) var(--s-7);
    }
    .page .prose { max-width: var(--prose); }
    .page .prose p { line-height: var(--lh-prose); }

    /* ───────── Responsive ───────── */
    @media (max-width: 860px) {
      .masthead__inner {
        grid-template-columns: auto auto;
        grid-template-rows: auto auto;
        gap: var(--s-3);
        padding: var(--s-3) var(--s-5);
      }
      .nav { grid-column: 1 / -1; justify-content: flex-start; gap: var(--s-5); overflow-x: auto; padding-bottom: var(--s-2); }
      .masthead__cta { display: none; }
      .wordmark__tag { display: none; }
      .footer__inner { grid-template-columns: 1fr 1fr; }
      .facts { grid-template-columns: 1fr; gap: 0; }
      .facts dt { padding-bottom: 0; border-bottom: 0; }
      .facts dd { padding-top: var(--s-2); }
      .section-head { grid-template-columns: 1fr; gap: var(--s-3); }
      .offering__body { grid-template-columns: 1fr; }
      .offering__price { text-align: left; flex-direction: row; gap: var(--s-3); align-items: baseline; }
    }
    @media (max-width: 560px) {
      .hero__title { max-width: 100%; }
      .week-strip__inner { grid-template-columns: 1fr; gap: var(--s-3); }
      .footer__inner { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
  <Masthead />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
