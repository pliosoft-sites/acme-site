---
import Wordmark from './Wordmark.astro';
import { NEXT_ROAST } from '../data/site';

const path = Astro.url.pathname;
const isCurrent = (p: string) =>
  p === '/' ? path === '/' : path === p || path.startsWith(p);

const nav: [string, string][] = [
  ['/', 'Coffee'],
  ['/offerings/', 'All offerings'],
  ['/wholesale/', 'Wholesale'],
  ['/about/', 'About'],
  ['/visit/', 'Visit'],
];
---
<header class="masthead">
  <div class="masthead__inner">
    <Wordmark />
    <nav class="nav" aria-label="Primary">
      {nav.map(([href, label]) => (
        <a
          href={href}
          class={isCurrent(href) ? 'is-active' : ''}
          aria-current={isCurrent(href) ? 'page' : undefined}
        >{label}</a>
      ))}
    </nav>
    <div class="masthead__cta">
      <span class="dot" aria-hidden="true"></span>
      <span>Roasted {NEXT_ROAST.dayName} · {NEXT_ROAST.label}</span>
    </div>
  </div>
</header>
