---
import Base from '../layouts/Base.astro';
---
<Base title="Visit — Acme Coffee Roasters">
  <p class="eyebrow">Visit</p>
  <h1>412 Maple Street.</h1>
  <p class="lede">
    The roaster runs Tuesday mornings. The shop's open Saturdays, 8 to noon.
    The door's the green one — look for the bike rack.
  </p>

  <h2>Hours</h2>
  <dl class="facts">
    <dt>Saturday</dt><dd>8:00 AM – 12:00 PM · retail, pickup, espresso bar.</dd>
    <dt>Tuesday</dt><dd>Roasting day. No retail. Wholesale pickups by arrangement.</dd>
    <dt>Other days</dt><dd>We're off.</dd>
  </dl>

  <h2>Getting in touch</h2>
  <dl class="facts">
    <dt>General</dt><dd><a href="mailto:hello@acmecoffee.example">hello@acmecoffee.example</a></dd>
    <dt>Wholesale</dt><dd><a href="mailto:wholesale@acmecoffee.example">wholesale@acmecoffee.example</a></dd>
    <dt>Phone</dt><dd>(555) 010-4120 · Saturdays only.</dd>
  </dl>

  <h2>Shipping</h2>
  <p>
    Order via email Monday–Friday. We ship USPS Priority on Mondays. A 12 oz
    bag is $18 shipped anywhere in the contiguous US.
  </p>
</Base>
